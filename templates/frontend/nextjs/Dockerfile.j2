FROM node:22-alpine AS builder

WORKDIR /build
COPY package.json package-lock.json* ./
RUN npm install

COPY . .

ARG API_URL=http://api.localhost
ENV NEXT_PUBLIC_API_URL=$API_URL

RUN npm run build

FROM node:22-alpine

RUN addgroup -g 1001 appuser && adduser -u 1001 -G appuser -D appuser

WORKDIR /home/appuser

COPY --from=builder /build/.next/standalone ./
COPY --chown=1001:1001 --from=builder /build/.next/static ./.next/static
COPY --from=builder /build/public ./public

COPY <<'ENTRYPOINT' /usr/local/bin/entrypoint.sh
#!/bin/sh
if [ -n "$API_URL" ]; then
  find /home/appuser/.next/static -name '*.js' -exec \
    sed -i "s|http://api.localhost|$API_URL|g" {} +
fi
export NEXT_PUBLIC_API_URL="${API_URL:-http://api.localhost}"
exec node server.js
ENTRYPOINT
RUN chmod +x /usr/local/bin/entrypoint.sh

USER 1001

EXPOSE 3000
ENV PORT=3000

CMD ["/usr/local/bin/entrypoint.sh"]
