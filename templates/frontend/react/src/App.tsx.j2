{% raw %}import { useEffect, useState } from "react";
import { checkHealth, createItem, deleteItem, fetchItems, Item } from "./lib/api";

export default function App() {
  const [items, setItems] = useState<Item[]>([]);
  const [healthy, setHealthy] = useState<boolean | null>(null);
  const [name, setName] = useState("");
  const [description, setDescription] = useState("");
  const [hostname, setHostname] = useState("");

  useEffect(() => {
    loadItems();
    checkHealth().then(setHealthy);
    setHostname(window.location.hostname);
  }, []);

  async function loadItems() {
    try {
      const data = await fetchItems();
      setItems(data);
    } catch {
      console.error("Failed to load items");
    }
  }

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault();
    if (!name.trim()) return;
    await createItem({ name, description: description || undefined });
    setName("");
    setDescription("");
    loadItems();
  }

  async function handleDelete(id: string) {
    await deleteItem(id);
    loadItems();
  }

  return (
    <main style={{ fontFamily: "system-ui, sans-serif", padding: "2rem" }}>
      <h1>{% endraw %}{{ name }}{% raw %}</h1>

      <div style={{ marginBottom: "1rem" }}>
        <span
          style={{
            display: "inline-block",
            width: 10,
            height: 10,
            borderRadius: "50%",
            backgroundColor:
              healthy === null ? "gray" : healthy ? "limegreen" : "red",
            marginRight: 6,
          }}
        />
        <small>
          Backend {healthy === null ? "checking..." : healthy ? "connected" : "unreachable"}
        </small>
        <small style={{ marginLeft: "1rem" }}>Host: {hostname}</small>
      </div>

      <form onSubmit={handleSubmit} style={{ marginBottom: "2rem" }}>
        <input
          value={name}
          onChange={(e) => setName(e.target.value)}
          placeholder="Item name"
          required
          style={{ marginRight: 8, padding: "0.4rem" }}
        />
        <input
          value={description}
          onChange={(e) => setDescription(e.target.value)}
          placeholder="Description (optional)"
          style={{ marginRight: 8, padding: "0.4rem" }}
        />
        <button type="submit" style={{ padding: "0.4rem 1rem" }}>
          Add
        </button>
      </form>

      {items.length === 0 ? (
        <p>No items yet.</p>
      ) : (
        <ul style={{ listStyle: "none", padding: 0 }}>
          {items.map((item) => (
            <li
              key={item.id}
              style={{
                padding: "0.5rem 0",
                borderBottom: "1px solid #eee",
                display: "flex",
                justifyContent: "space-between",
                alignItems: "center",
              }}
            >
              <div>
                <strong>{item.name}</strong>
                {item.description && (
                  <span style={{ color: "#666", marginLeft: 8 }}>
                    {item.description}
                  </span>
                )}
              </div>
              <button
                onClick={() => handleDelete(item.id)}
                style={{ color: "red", cursor: "pointer", background: "none", border: "none" }}
              >
                delete
              </button>
            </li>
          ))}
        </ul>
      )}
    </main>
  );
}
{% endraw %}
