FROM golang:1.22-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o server ./cmd/server

FROM alpine:3.20

RUN addgroup -g 1001 appuser && adduser -u 1001 -G appuser -D appuser

COPY --from=builder /build/server /usr/local/bin/server

USER 1001

EXPOSE 8000

CMD ["server"]
