package handlers

import (
	"context"
	"encoding/json"
	"net/http"

	"{{ name }}-backend/internal/middleware"
	"{{ name }}-backend/internal/models"

	"github.com/go-chi/chi/v5"
	"github.com/google/uuid"
	"github.com/jackc/pgx/v5/pgxpool"
)

type TodoHandler struct {
	db *pgxpool.Pool
}

func NewTodoHandler(db *pgxpool.Pool) *TodoHandler {
	return &TodoHandler{db: db}
}

func (h *TodoHandler) List(w http.ResponseWriter, r *http.Request) {
	userID := middleware.GetUserID(r)

	rows, err := h.db.Query(
		context.Background(),
		"SELECT id, title, description, completed, created_at FROM todos WHERE user_id = $1 ORDER BY created_at DESC",
		userID,
	)
	if err != nil {
		writeJSON(w, http.StatusInternalServerError, map[string]string{"detail": "Database error"})
		return
	}
	defer rows.Close()

	todos := []models.Todo{}
	for rows.Next() {
		var t models.Todo
		if err := rows.Scan(&t.ID, &t.Title, &t.Description, &t.Completed, &t.CreatedAt); err != nil {
			writeJSON(w, http.StatusInternalServerError, map[string]string{"detail": "Database error"})
			return
		}
		todos = append(todos, t)
	}

	writeJSON(w, http.StatusOK, todos)
}

func (h *TodoHandler) Create(w http.ResponseWriter, r *http.Request) {
	userID := middleware.GetUserID(r)

	var req models.TodoCreate
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		writeJSON(w, http.StatusBadRequest, map[string]string{"detail": "Invalid request body"})
		return
	}

	var t models.Todo
	id := uuid.New().String()
	err := h.db.QueryRow(
		context.Background(),
		"INSERT INTO todos (id, user_id, title, description) VALUES ($1, $2, $3, $4) RETURNING id, title, description, completed, created_at",
		id, userID, req.Title, req.Description,
	).Scan(&t.ID, &t.Title, &t.Description, &t.Completed, &t.CreatedAt)
	if err != nil {
		writeJSON(w, http.StatusInternalServerError, map[string]string{"detail": "Database error"})
		return
	}

	writeJSON(w, http.StatusCreated, t)
}

func (h *TodoHandler) Get(w http.ResponseWriter, r *http.Request) {
	userID := middleware.GetUserID(r)
	todoID := chi.URLParam(r, "id")

	var t models.Todo
	err := h.db.QueryRow(
		context.Background(),
		"SELECT id, title, description, completed, created_at FROM todos WHERE id = $1 AND user_id = $2",
		todoID, userID,
	).Scan(&t.ID, &t.Title, &t.Description, &t.Completed, &t.CreatedAt)
	if err != nil {
		writeJSON(w, http.StatusNotFound, map[string]string{"detail": "Todo not found"})
		return
	}

	writeJSON(w, http.StatusOK, t)
}

func (h *TodoHandler) Update(w http.ResponseWriter, r *http.Request) {
	userID := middleware.GetUserID(r)
	todoID := chi.URLParam(r, "id")

	var existing models.Todo
	err := h.db.QueryRow(
		context.Background(),
		"SELECT id, title, description, completed, created_at FROM todos WHERE id = $1 AND user_id = $2",
		todoID, userID,
	).Scan(&existing.ID, &existing.Title, &existing.Description, &existing.Completed, &existing.CreatedAt)
	if err != nil {
		writeJSON(w, http.StatusNotFound, map[string]string{"detail": "Todo not found"})
		return
	}

	var req models.TodoUpdate
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		writeJSON(w, http.StatusBadRequest, map[string]string{"detail": "Invalid request body"})
		return
	}

	if req.Title != nil {
		existing.Title = *req.Title
	}
	if req.Description != nil {
		existing.Description = req.Description
	}
	if req.Completed != nil {
		existing.Completed = *req.Completed
	}

	_, err = h.db.Exec(
		context.Background(),
		"UPDATE todos SET title = $1, description = $2, completed = $3 WHERE id = $4 AND user_id = $5",
		existing.Title, existing.Description, existing.Completed, todoID, userID,
	)
	if err != nil {
		writeJSON(w, http.StatusInternalServerError, map[string]string{"detail": "Database error"})
		return
	}

	writeJSON(w, http.StatusOK, existing)
}

func (h *TodoHandler) Delete(w http.ResponseWriter, r *http.Request) {
	userID := middleware.GetUserID(r)
	todoID := chi.URLParam(r, "id")

	tag, err := h.db.Exec(
		context.Background(),
		"DELETE FROM todos WHERE id = $1 AND user_id = $2",
		todoID, userID,
	)
	if err != nil || tag.RowsAffected() == 0 {
		writeJSON(w, http.StatusNotFound, map[string]string{"detail": "Todo not found"})
		return
	}

	w.WriteHeader(http.StatusNoContent)
}
