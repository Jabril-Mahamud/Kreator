package handlers

import (
	"context"
	"encoding/json"
	"log/slog"
	"net/http"

	"{{ name }}-backend/internal/auth"
	"{{ name }}-backend/internal/models"

	"github.com/google/uuid"
	"github.com/jackc/pgx/v5/pgxpool"
)

type AuthHandler struct {
	db     *pgxpool.Pool
	secret string
}

func NewAuthHandler(db *pgxpool.Pool, secret string) *AuthHandler {
	return &AuthHandler{db: db, secret: secret}
}

func (h *AuthHandler) Register(w http.ResponseWriter, r *http.Request) {
	var req models.AuthRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		writeJSON(w, http.StatusBadRequest, map[string]string{"detail": "Invalid request body"})
		return
	}

	hash, err := auth.HashPassword(req.Password)
	if err != nil {
		slog.Error("failed to hash password", "error", err)
		writeJSON(w, http.StatusInternalServerError, map[string]string{"detail": "Internal error"})
		return
	}

	id := uuid.New().String()
	_, err = h.db.Exec(
		context.Background(),
		"INSERT INTO users (id, username, password_hash) VALUES ($1, $2, $3)",
		id, req.Username, hash,
	)
	if err != nil {
		writeJSON(w, http.StatusConflict, map[string]string{"detail": "Username taken"})
		return
	}

	writeJSON(w, http.StatusCreated, models.RegisterResponse{ID: id, Username: req.Username})
}

func (h *AuthHandler) Login(w http.ResponseWriter, r *http.Request) {
	var req models.AuthRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		writeJSON(w, http.StatusBadRequest, map[string]string{"detail": "Invalid request body"})
		return
	}

	var user models.User
	err := h.db.QueryRow(
		context.Background(),
		"SELECT id, username, password_hash FROM users WHERE username = $1",
		req.Username,
	).Scan(&user.ID, &user.Username, &user.PasswordHash)
	if err != nil {
		writeJSON(w, http.StatusUnauthorized, map[string]string{"detail": "Invalid credentials"})
		return
	}

	if !auth.VerifyPassword(req.Password, user.PasswordHash) {
		writeJSON(w, http.StatusUnauthorized, map[string]string{"detail": "Invalid credentials"})
		return
	}

	token, err := auth.CreateToken(user.ID, h.secret)
	if err != nil {
		slog.Error("failed to create token", "error", err)
		writeJSON(w, http.StatusInternalServerError, map[string]string{"detail": "Internal error"})
		return
	}

	writeJSON(w, http.StatusOK, models.LoginResponse{Token: token})
}

func writeJSON(w http.ResponseWriter, status int, data any) {
	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(status)
	json.NewEncoder(w).Encode(data)
}
