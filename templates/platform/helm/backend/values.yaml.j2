replicaCount: 1

image:
  repository: localhost:5001/{{ name }}-backend
  tag: latest
  pullPolicy: Always

service:
  type: ClusterIP
  port: 8000

ingress:
  enabled: true
  host: api.localhost

resources:
  requests:
    cpu: 100m
    memory: 128Mi
  limits:
    cpu: 500m
    memory: 256Mi

secretName: {{ name }}-backend-secrets

env:
  {{ name | upper | replace('-', '_') }}_DATABASE_URL: ""
  {{ name | upper | replace('-', '_') }}_OTLP_ENABLED: "false"

autoscaling:
  enabled: true
  minReplicas: 1
  maxReplicas: 5
  targetCPUUtilizationPercentage: 70
