replicaCount: 1

image:
  repository: localhost:5001/{{ name }}-backend
  tag: latest
  pullPolicy: Always

service:
  type: ClusterIP
  port: 8000

ingress:
  enabled: true
  host: api.localhost

resources:
  requests:
    cpu: 100m
    memory: 128Mi
  limits:
    cpu: 500m
    memory: 256Mi

autoscaling:
  enabled: true
  minReplicas: 1
  maxReplicas: 5
  targetCPUUtilization: 70

dbSecretName: {{ name }}-db-credentials
jwtSecretName: {{ name }}-jwt-secret
configMapName: {{ name }}-backend-config
