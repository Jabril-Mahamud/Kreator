apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ name }}-root
  namespace: argocd
spec:
  project: default
  source:
    path: deploy/argocd/apps
    repoURL: https://github.com/placeholder/{{ name }}.git
    targetRevision: HEAD
  destination:
    server: https://kubernetes.default.svc
    namespace: argocd
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
