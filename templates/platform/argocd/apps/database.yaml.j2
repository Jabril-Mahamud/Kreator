apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ name }}-database
  namespace: argocd
spec:
  project: default
  source:
    repoURL: {{ repo_url }}
    targetRevision: HEAD
    path: infrastructure/claims
  destination:
    server: https://kubernetes.default.svc
    namespace: default
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
