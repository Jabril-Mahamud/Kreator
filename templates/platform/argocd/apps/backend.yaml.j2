apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ name }}-backend
  namespace: argocd
spec:
  project: {{ name }}
  source:
    repoURL: {{ repo_url }}
    targetRevision: HEAD
    path: deploy/helm/backend
  destination:
    server: https://kubernetes.default.svc
    namespace: {{ name }}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
