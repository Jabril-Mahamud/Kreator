apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ name }}-backend
  namespace: argocd
spec:
  project: default
  source:
    path: deploy/helm/backend
    repoURL: https://github.com/placeholder/{{ name }}.git
    targetRevision: HEAD
  destination:
    server: https://kubernetes.default.svc
    namespace: default
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
