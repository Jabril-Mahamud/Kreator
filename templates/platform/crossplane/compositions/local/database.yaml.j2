apiVersion: apiextensions.crossplane.io/v1
kind: Composition
metadata:
  name: local-database
  labels:
    crossplane.io/xrd: xdatabases.kreator.dev
    provider: local
spec:
  compositeTypeRef:
    apiVersion: kreator.dev/v1alpha1
    kind: XDatabase
  resources:
    - name: postgres-secret
      base:
        apiVersion: kubernetes.crossplane.io/v1alpha2
        kind: Object
        spec:
          forProvider:
            manifest:
              apiVersion: v1
              kind: Secret
              metadata:
                name: {{ name }}-db-credentials
                namespace: {{ name }}
              type: Opaque
              stringData:
                POSTGRES_USER: postgres
                POSTGRES_PASSWORD: postgres
                POSTGRES_DB: {{ name }}
                DATABASE_URL: "postgresql+asyncpg://postgres:postgres@{{ name }}-db:5432/{{ name }}"
          providerConfigRef:
            name: provider-kubernetes
      patches:
        - fromFieldPath: spec.parameters.namespace
          toFieldPath: spec.forProvider.manifest.metadata.namespace

    - name: postgres-statefulset
      base:
        apiVersion: kubernetes.crossplane.io/v1alpha2
        kind: Object
        spec:
          forProvider:
            manifest:
              apiVersion: apps/v1
              kind: StatefulSet
              metadata:
                name: {{ name }}-db
                namespace: {{ name }}
              spec:
                serviceName: {{ name }}-db
                replicas: 1
                selector:
                  matchLabels:
                    app: {{ name }}-db
                template:
                  metadata:
                    labels:
                      app: {{ name }}-db
                  spec:
                    containers:
                      - name: postgres
                        image: postgres:16-alpine
                        ports:
                          - containerPort: 5432
                        envFrom:
                          - secretRef:
                              name: {{ name }}-db-credentials
                        resources:
                          requests:
                            cpu: 100m
                            memory: 256Mi
                          limits:
                            cpu: 500m
                            memory: 512Mi
                        readinessProbe:
                          exec:
                            command: ["pg_isready", "-U", "postgres"]
                          initialDelaySeconds: 5
                          periodSeconds: 5
          providerConfigRef:
            name: provider-kubernetes
      patches:
        - fromFieldPath: spec.parameters.namespace
          toFieldPath: spec.forProvider.manifest.metadata.namespace

    - name: postgres-service
      base:
        apiVersion: kubernetes.crossplane.io/v1alpha2
        kind: Object
        spec:
          forProvider:
            manifest:
              apiVersion: v1
              kind: Service
              metadata:
                name: {{ name }}-db
                namespace: {{ name }}
              spec:
                selector:
                  app: {{ name }}-db
                ports:
                  - port: 5432
                    targetPort: 5432
                clusterIP: None
          providerConfigRef:
            name: provider-kubernetes
      patches:
        - fromFieldPath: spec.parameters.namespace
          toFieldPath: spec.forProvider.manifest.metadata.namespace
